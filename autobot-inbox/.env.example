API_PORT=3001
DASHBOARD_PORT=3100

# ─────────────────────────────────────────────────────────────────────
# Platform-injected / OS (do NOT set here — documented for completeness)
# ─────────────────────────────────────────────────────────────────────
# PORT                     — Railway assigns the listening port.
# RAILWAY_PUBLIC_DOMAIN    — Railway injects the public domain.
# HOME, PATH               — OS-provided.
# DEBUG                    — ad-hoc debug flag.
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH — set only in browser-scraping images.
