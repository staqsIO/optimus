# AutoBot Inbox — Environment Variables
# =====================================================================
# Copy this to .env and fill in your values. PLACEHOLDERS ONLY — never
# commit a real secret value here.
#
# Marker legend (see lib/runtime/governance/required-env-preflight.js):
#   [REQUIRED]     production boot is REFUSED without it (fail-fast).
#                  Skipped in demo mode (synthetic data + PGlite).
#   [RECOMMENDED]  production warns loudly if unset; degraded, not blocked.
#   [optional]     integration-specific or has a safe default; unset is fine.
#   [test/ci]      only read by tests/tooling — never set in production.
#
# This file is regenerated from actual `process.env.*` usage across
# autobot-inbox/src, lib/, and agents/ (Plan 030 / #474). A key here means the
# code has a real consumer for it.

# ─────────────────────────────────────────────────────────────────────
# Core / Required
# ─────────────────────────────────────────────────────────────────────

# [REQUIRED] Anthropic API key — baseline LLM provider for every agent tier.
# Get from console.anthropic.com.
ANTHROPIC_API_KEY=

# [REQUIRED] Postgres connection for the shared task graph (production/Supabase).
# Omit for PGlite in-process mode (demo/dev only — ephemeral, not for prod).
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# [optional] Separate read-replica/query URL (falls back to DATABASE_URL).
# DATABASE_URL_QUERY=
# [optional] Max Postgres pool connections (default tuned for Supabase pooler).
# DB_POOL_MAX=
# [optional] pg LISTEN client keepalive interval (ms).
# PG_LISTENER_KEEPALIVE_MS=
# [optional] PGlite data directory (dev/demo only).
# PGLITE_DATA_DIR=
# [optional] Dedicated password for the RLS-scoped agent DB role.
# AUTOBOT_AGENT_DB_PASSWORD=

# [optional] Node environment. Set to 'production' on real deploys — this is the
# signal every production preflight (env + Model Armor) keys off of.
# NODE_ENV=production

# [optional] Demo mode: synthetic emails, no Gmail/DB required. Implies
# LLM_SINGLE_PROVIDER=anthropic (see below) so the whole org runs on
# ANTHROPIC_API_KEY alone — no OPENROUTER_API_KEY needed.
# DEMO_MODE=1

# [optional] Force every agent onto a single LLM provider, regardless of what
# config/agents.json's per-model `provider` fields say. Set to "anthropic" to
# run the whole org on ANTHROPIC_API_KEY alone (zero-config OSS boot) — models
# configured for other providers (openrouter, etc.) are transparently remapped
# to an Anthropic model instead of throwing on a missing API key. Automatically
# set when DEMO_MODE=1 and left unset. Prod (unset) is unaffected.
# LLM_SINGLE_PROVIDER=anthropic
# [optional] Exact model key to remap to when LLM_SINGLE_PROVIDER is set.
# Defaults to the first models-config entry whose provider matches.
# LLM_SINGLE_PROVIDER_MODEL=

# [optional] Process role: run a subset in one process.
# Values: ingestion | agents | api | full (default). Split into Railway
# services when volume demands it.
PROCESS_ROLE=full

# [optional] Comma-separated agent IDs to run (overrides agents.json enabled).
# e.g. M1 CLI runner: AGENTS_ENABLED=executor-redesign,executor-coder
# AGENTS_ENABLED=
# [optional] Path override for agents.json.
# AGENTS_CONFIG_PATH=
# [optional] Path override for the SQL migrations directory.
# SQL_DIR=
# [optional] Executor driver override (cli | managed | api).
# EXECUTOR_DRIVER=
# [optional] Max concurrent Claude CLI executor processes.
# MAX_CLAUDE_CONCURRENCY=
# [optional] Graceful-drain timeout on shutdown (ms).
# DRAIN_TIMEOUT_MS=

# ─────────────────────────────────────────────────────────────────────
# Auth & Identity (JWT / secrets)
# ─────────────────────────────────────────────────────────────────────
# JWT signing keys may be injected as an inline PEM (*_PEM) or a file path
# (*_PATH). The preflight treats either form as satisfying the key.
# Dev/demo: unset is fine — an ephemeral RSA keypair is generated at boot.
# Generate a persistent key (RS256):
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out agent-jwt.pem

# [RECOMMENDED] Agent JWT signing key (agent identity / scoped tokens, STAQPRO-263).
# AGENT_JWT_KEY_PEM=
# AGENT_JWT_KEY_PATH=
# [optional] Enforce agent JWT (agent tick fails closed when true).
# REQUIRE_AGENT_JWT=false
# [RECOMMENDED] Board JWT signing key (board-workstation auth, OPT-148/ADR-019).
# Must be the SAME keypair on the board and the API or board users 401.
# BOARD_JWT_KEY_PEM=
# [RECOMMENDED] Customer JWT signing key (external customer principals).
# CUSTOMER_JWT_KEY_PEM=
# [RECOMMENDED] Capability-receipt signing key.
# CAPABILITY_RECEIPT_KEY_PEM=
# [optional] Require federation claims on cross-org tokens.
# REQUIRE_FEDERATION_CLAIMS=false

# [RECOMMENDED] Ops/admin API authentication secret.
# API_SECRET=
# [RECOMMENDED] Scheduled-job (cron) endpoint authentication secret.
# CRON_SECRET=
# [optional] Generic MCP/direct-API key.
# API_KEY=
# [RECOMMENDED] Credential encryption for stored OAuth tokens (multi-account).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY=
# [optional] HMAC signing key for agent identity claims (ADR-015).
# Generate: openssl rand -hex 32
AGENT_SIGNING_KEY=

# [optional] Org identity.
# OPTIMUS_ORG_ID=
# OPTIMUS_ORG_DID=
# ORG_DID=
# GBRAIN_OWNER_ID=
# [optional] Allowed CORS origins for the API (comma-separated).
# ALLOWED_ORIGINS=
# [optional] Base URLs.
# API_BASE_URL=
# APP_URL=
# DASHBOARD_URL=
# OPTIMUS_API_BASE_URL=

# ─────────────────────────────────────────────────────────────────────
# LLM Providers (beyond Anthropic)
# ─────────────────────────────────────────────────────────────────────

# [RECOMMENDED] Gemini — strategist / architect tiers.
# GEMINI_API_KEY=
# [optional] Local gemini CLI binary path.
# GEMINI_BIN=
# [RECOMMENDED] OpenAI — embeddings + RAG/Responses web search.
# OPENAI_API_KEY=
# [optional] OpenRouter — non-Anthropic models via openrouter.ai/keys. REQUIRED
# for prod's default multi-provider agent config (Strategist/Architect/
# Orchestrator route to openrouter models) UNLESS LLM_SINGLE_PROVIDER=anthropic.
OPENROUTER_API_KEY=
# [optional] Claude Code CLI OAuth token (managed executor driver).
# CLAUDE_CODE_OAUTH_TOKEN=
# CLAUDE_CODE_OAUTH_TOKEN_FALLBACK=
# [optional] Local claude CLI binary path.
# CLAUDE_BIN=
# [optional] Ollama on-prem inference (DORMANT — OPT-39; only when an agent sets
# provider="ollama"). De-dormancy: >$1500/mo sustained OR on-prem contract.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

