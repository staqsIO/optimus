# ASSEMBLYAI_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# G8: Model Armor (prompt-injection screening)
# ─────────────────────────────────────────────────────────────────────
# PRODUCTION REQUIREMENT (P1/P2): when agents run with NODE_ENV=production, the
# preflight (lib/runtime/governance/model-armor-preflight.js) REFUSES to boot
# unless MODEL_ARMOR_MODE=block AND MODEL_ARMOR_TEMPLATE is set.
# The Model Armor template resource path. This env var is the source of truth;
# config/gates.json G8 ships only a non-secret placeholder
# (projects/YOUR_GCP_PROJECT/...) which is treated as unconfigured until you set
# this. Set it to your own GCP project's template path.
MODEL_ARMOR_TEMPLATE=
# MODEL_ARMOR_MODE=warn
# MODEL_ARMOR_BLOCK_THRESHOLD=HIGH
# MODEL_ARMOR_FAIL_OPEN=false

# ─────────────────────────────────────────────────────────────────────
# G2/G7 runtime pattern overlay (deploy-specific commitment/precedent regexes)
# ─────────────────────────────────────────────────────────────────────
# The G2 (legal commitment) and G7 (precedent) baseline regex lists live in the
# public config/gates.json. To ADD deployment-specific patterns WITHOUT editing
# public config, set newline-delimited regex strings here (one pattern per line;
# in a dotenv file use a double-quoted value with \n between patterns). Extras
# are merged on top of the baseline (never replace it). An invalid regex line is
# logged and skipped — a bad value can only reduce coverage, never crash the gate.
# G2_PATTERNS_EXTRA="\\bguarantee\\b\n\\bindemnify\\b"
# G7_PATTERNS_EXTRA="\\bSLA\\b"

# ─────────────────────────────────────────────────────────────────────
# Front door (intent-fidelity serving)
# ─────────────────────────────────────────────────────────────────────
# FRONT_DOOR_SERVE_BY_MATCH=false
# FRONT_DOOR_CATALOG_HOSTS=
# FRONT_DOOR_COLDTAIL=
# FRONT_DOOR_ENRICH_MODEL=

