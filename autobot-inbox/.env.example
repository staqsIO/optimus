# EMBEDDING_MODEL=
# EMBEDDING_DIMENSIONS=
# EMBEDDING_BATCH_SIZE=
# [optional] Alternative embedding/rerank providers.
# VOYAGE_API_KEY=
# COHERE_API_KEY=
