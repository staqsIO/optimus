# Optimus Runner — Environment Variables
# Copy to .env on the runner machine. Only DATABASE_URL is required.

# ──────────────────────────────────────────────────────────────
# REQUIRED: Shared Postgres database
# ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://autobot:password@your-db-host:5432/autobot

# ──────────────────────────────────────────────────────────────
# RUNNER IDENTITY (optional, auto-generated if omitted)
# ──────────────────────────────────────────────────────────────
# Human-friendly name shown in logs and audit trail
# RUNNER_ID=mac-m1-studio

# ──────────────────────────────────────────────────────────────
# GITHUB AUTH (one of these — executor-coder needs repo access)
# ──────────────────────────────────────────────────────────────
# Option 1: GitHub App (preferred — fine-grained permissions, auto-expiring tokens)
# PEM key lives at ~/.keys/ (outside any repo — zero commit risk)
# GITHUB_APP_ID=<your-app-id>
# GITHUB_APP_PRIVATE_KEY_PATH=$HOME/.keys/optimus-agent.pem
# GITHUB_APP_INSTALLATION_ID=<your-installation-id>

# Option 2: gh CLI auth (simplest — run `gh auth login` on this machine)
# No env var needed, gh reads ~/.config/gh/hosts.yml

# Option 3: Personal access token (fallback)
# GITHUB_TOKEN=ghp_xxx

# ──────────────────────────────────────────────────────────────
# OPTIONAL: Budget and notifications
# ──────────────────────────────────────────────────────────────
# Daily LLM budget ceiling (default: $20)
# DAILY_BUDGET_USD=20

# Slack notifications when PRs are created
# SLACK_NOTIFICATIONS_CHANNEL=C0123456789

# ──────────────────────────────────────────────────────────────
# ANTHROPIC API KEY (required for executor-research)
# ──────────────────────────────────────────────────────────────
# executor-coder uses Claude CLI subscription (no key needed)
# executor-research uses callLLM() which needs the SDK key
ANTHROPIC_API_KEY=sk-ant-xxx

# ──────────────────────────────────────────────────────────────
# NOT NEEDED for runner mode:
#   GMAIL_*            — no email polling
#   SLACK_BOT_TOKEN    — no Slack listener
#   TELEGRAM_*         — no Telegram listener
#   API_PORT           — no API server
# ──────────────────────────────────────────────────────────────
