{
  "name": "autobot-inbox",
  "version": "0.1.0",
  "description": "AI inbox management — first Optimus organization running the full autobot-spec architecture",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "cli": "node src/cli/index.js",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "backfill:participants": "node scripts/backfill-participants.js",
    "backfill:gemini-happened-at": "node scripts/backfill-gemini-happened-at.js",
    "test:weekly-recap": "node scripts/test-weekly-recap.js",
    "setup": "bash scripts/setup-gcp.sh",
    "setup-gmail": "node scripts/setup-gmail.js",
    "setup-outlook": "node scripts/setup-outlook.js",
    "bootstrap-voice": "node scripts/bootstrap-voice.js",
    "embed-drafts": "node scripts/embed-drafts.js",
    "seed-demo": "node scripts/seed-demo.js",
    "seed-brand-assets": "node scripts/seed-brand-assets.js",
    "demo": "node src/index.js --demo",
    "electron": "cd electron && npx electron .",
    "electron:demo": "cd electron && npx electron . --demo",
    "electron:install": "cd electron && npm install",
    "electron:build": "cd electron && npm run build",
    "runner": "node src/runner.js",
    "runner:dev": "node --watch src/runner.js",
    "runner:setup": "bash scripts/setup-runner.sh",
    "test": "node scripts/run-tests.js",
    "test:ci": "node scripts/run-tests.js",
    "test:raw": "node --experimental-test-module-mocks --test test/*.test.js",
    "test:integration": "node --test --test-force-exit test/*-integration.test.js",
    "compile-agents": "node tools/compile-agents.js",
    "compile-agents:validate": "node tools/compile-agents.js --validate",
    "compile-agents:diff": "node tools/compile-agents.js --diff",
    "lint": "eslint src test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@aws-sdk/client-s3": "^3.1006.0",
    "@azure/msal-node": "^5.0.5",
    "@electric-sql/pglite": "^0.4.2",
    "@google/generative-ai": "^0.24.1",
    "@slack/bolt": "^4.6.0",
    "archiver": "^7.0.1",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.7",
    "googleapis": "^144.0.0",
    "js-yaml": "^4.1.1",
    "node-telegram-bot-api": "^0.67.0",
    "nodemailer": "^9.0.3",
    "openai": "^6.32.0",
    "pg": "^8.19.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "fast-check": "^3.23.0"
  },
  "optionalDependencies": {
    "chrome-launcher": "^1.1.0",
    "lighthouse": "^12.0.0",
    "playwright": "^1.52.0"
  },
  "overrides": {
    "form-data": "^4.0.2",
    "qs": "^6.14.1",
    "tough-cookie": "^4.1.3"
  },
  "private": true,
  "license": "Apache-2.0"
}
