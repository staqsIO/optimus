# Board Workstation — Environment Variables
# Copy this to .env.local and fill in your values.

# Redis — required for encrypted API key storage (ioredis)
REDIS_URL=redis://localhost:6379

# AES-256-GCM key for encrypting stored Anthropic API keys
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY_ENCRYPTION_SECRET=

# NextAuth
NEXTAUTH_URL=http://localhost:3200
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=

# GitHub OAuth app (create at github.com/settings/applications/new)
# Authorization callback URL: http://localhost:3200/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=

# Comma-separated GitHub usernames always permitted to sign in
BOARD_MEMBERS=ecgang,ConsultingFuture4200

# AutoBot-Inbox API (backend)
OPS_API_URL=http://localhost:3001
